# Amagra — environment configuration
# Copy to .env and fill in values. Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────

# Ollama host (default: local Docker service)
OLLAMA_HOST=http://ollama:11434

# ── Environment ───────────────────────────────────────────────

# "production" enforces REQUIRE_AUTH=1 (startup error if auth is off)
# "development" (default) allows REQUIRE_AUTH=0 with a startup warning
ENV=development

# ── Authentication ────────────────────────────────────────────

# Set to "1" to enforce X-API-Key on /ask, /tasks/*, /memory/*, /feedback
# Set to "0" for local development without auth
# REQUIRE_AUTH=1 is REQUIRED when ENV=production
REQUIRE_AUTH=0

# Admin token — required to access /admin/* endpoints from non-localhost.
# If unset, /admin/* is only reachable from 127.0.0.1 (localhost only).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# ── Stripe (required for paid plans) ─────────────────────────

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get from https://dashboard.stripe.com/webhooks after registering endpoint
# Endpoint URL: https://yourdomain.com/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_...           # Developer — $39/month
STRIPE_TEAM_PRICE_ID=price_...      # Team — $249/month

# ── Email (required for automated key delivery) ───────────────

# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....

# Must be a verified sender in SendGrid
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=Amagra

# ── Application ───────────────────────────────────────────────

# Public base URL (used for Stripe success/cancel redirects)
BASE_URL=http://localhost:3000

# Ollama model to use (pulled at startup by docker-compose)
OLLAMA_MODEL=phi4-mini

# Ollama API base URL when running outside docker-compose
# (code default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Per-call generation timeout in seconds (code default: 120). Caps a single
# generate/ask so a hung or overloaded Ollama can't stall a request forever.
# Set to 0 to disable the ceiling.
OLLAMA_TIMEOUT=120

# ── Providers (optional) ──────────────────────────────────────

# Backend for the reasoning brain and signal classifier.
# "ollama" (default) is currently the only option for SIGNAL_PROVIDER.
BRAIN_PROVIDER=ollama
SIGNAL_PROVIDER=ollama

# ── Claude enhancement (optional) ─────────────────────────────

# When set, ambiguous/complex queries can escalate to Claude.
# Leave empty to run fully local.
ANTHROPIC_API_KEY=

# Claude model used for enhancement when the API key is set
ENHANCE_MODEL=claude-sonnet-4-6
