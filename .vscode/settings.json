// Amagra "Gilded Calm" — workspace editor theme (warm-white + gold).
// Derived 1:1 from ui/src/theme.js so the editor matches the app.
// Pairs best with a light base theme (e.g. "Light Modern"). Local-only —
// safe to delete this file to revert. Full annotated copy lives in scratchpad.
{
  "workbench.colorCustomizations": {
    "editor.background": "#FAF7F2",
    "editor.foreground": "#2E2010",
    "editorGutter.background": "#FAF7F2",
    "sideBar.background": "#F0E9DF",
    "sideBar.foreground": "#5C4030",
    "sideBarSectionHeader.background": "#F4F0E8",
    "sideBarTitle.foreground": "#8A5A00",
    "activityBar.background": "#F4F0E8",
    "activityBar.foreground": "#8A5A00",
    "activityBar.inactiveForeground": "#A08A6C",
    "activityBarBadge.background": "#C48808",
    "activityBarBadge.foreground": "#2E2010",
    "editorGroupHeader.tabsBackground": "#F0E9DF",
    "titleBar.activeBackground": "#F0E9DF",
    "titleBar.activeForeground": "#2E2010",
    "titleBar.inactiveBackground": "#F4F0E8",
    "panel.background": "#FAF7F2",
    "panelTitle.activeForeground": "#8A5A00",
    "panelTitle.activeBorder": "#C48808",

    "tab.activeBackground": "#FAF7F2",
    "tab.activeForeground": "#2E2010",
    "tab.activeBorderTop": "#C48808",
    "tab.inactiveBackground": "#F0E9DF",
    "tab.inactiveForeground": "#806044",
    "tab.border": "#E0D6C4",
    "tab.hoverBackground": "#F4F0E8",

    "statusBar.background": "#C48808",
    "statusBar.foreground": "#2E2010",
    "statusBar.noFolderBackground": "#9A6C00",
    "statusBar.debuggingBackground": "#B42318",
    "statusBarItem.remoteBackground": "#9A6C00",
    "statusBarItem.remoteForeground": "#FFF7E6",

    "focusBorder": "#C48808",
    "editorCursor.foreground": "#9A6C00",
    "editor.lineHighlightBackground": "#F4F0E8",
    "editor.selectionBackground": "#EFE2C4",
    "editor.selectionHighlightBackground": "#F1E7CC",
    "editor.wordHighlightBackground": "#F1E7CC",
    "editor.findMatchBackground": "#DEB838",
    "editor.findMatchHighlightBackground": "#FFE88066",
    "editorLineNumber.foreground": "#BBA787",
    "editorLineNumber.activeForeground": "#8A5A00",
    "editorIndentGuide.background1": "#E8DECB",
    "editorIndentGuide.activeBackground1": "#C48808",
    "editorBracketMatch.border": "#C48808",

    "list.activeSelectionBackground": "#EFE2C4",
    "list.activeSelectionForeground": "#2E2010",
    "list.inactiveSelectionBackground": "#F1E7CC",
    "list.hoverBackground": "#F4F0E8",
    "list.highlightForeground": "#9A6C00",

    "button.background": "#C48808",
    "button.foreground": "#2E2010",
    "button.hoverBackground": "#9A6C00",
    "badge.background": "#C48808",
    "badge.foreground": "#2E2010",
    "input.background": "#FAF7F2",
    "input.border": "#E0D6C4",
    "inputOption.activeBorder": "#C48808",
    "dropdown.background": "#FAF7F2",

    "contrastBorder": "#E0D6C4",
    "editorGroup.border": "#E0D6C4",
    "panel.border": "#E0D6C4",
    "sideBar.border": "#E0D6C4",
    "tab.activeBorder": "#FAF7F2",

    "gitDecoration.modifiedResourceForeground": "#A16207",
    "gitDecoration.untrackedResourceForeground": "#15803D",
    "gitDecoration.deletedResourceForeground": "#B42318",
    "editorError.foreground": "#B42318",
    "editorWarning.foreground": "#A16207",
    "editorInfo.foreground": "#1E5A8A",
    "terminal.background": "#F0E9DF",
    "terminal.foreground": "#2E2010"
  },

  "editor.tokenColorCustomizations": {
    "comments": "#9A7A60",
    "textMateRules": [
      { "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "foreground": "#9A7A60", "fontStyle": "italic" } },
      { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
        "settings": { "foreground": "#9A6C00" } },
      { "scope": ["string", "string.quoted", "punctuation.definition.string"],
        "settings": { "foreground": "#C06040" } },
      { "scope": ["constant.numeric", "constant.language", "constant.character"],
        "settings": { "foreground": "#BE185D" } },
      { "scope": ["entity.name.function", "support.function", "meta.function-call"],
        "settings": { "foreground": "#1E5A8A" } },
      { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
        "settings": { "foreground": "#0F766E" } },
      { "scope": ["variable", "variable.other", "meta.definition.variable"],
        "settings": { "foreground": "#2E2010" } },
      { "scope": ["variable.parameter"],
        "settings": { "foreground": "#5C4030" } },
      { "scope": ["entity.name.tag"],
        "settings": { "foreground": "#7E3F8F" } },
      { "scope": ["entity.other.attribute-name"],
        "settings": { "foreground": "#0E7490" } },
      { "scope": ["keyword.operator"],
        "settings": { "foreground": "#806044" } },
      { "scope": ["markup.heading", "entity.name.section"],
        "settings": { "foreground": "#8A5A00", "fontStyle": "bold" } }
    ]
  }
}
